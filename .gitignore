# Dados reais da empresa (confidenciais) — nunca versionar
*.xlsx
*.xls
*.csv
WK/*.html
WK/data/*.json
# cache da coleta pela API (itens de pedido + relatório baixado)
WK/cache/
# zips de distribuição: costumam levar dentro os HTML/JSON gerados (dados reais)
*.zip

# Chart.js já está em WK/assets/ — não versionar as cópias do protótipo (3,5 MB cada)
WK/SCM_Moderno/script*.js

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
ENV/

# PyInstaller (build local do .exe — pastas de trabalho, não versionar)
build/
dist/
*.spec

# Streamlit
.streamlit/secrets.toml

# Configuração local do Claude Code (específica da máquina)
.claude/settings.local.json

# Sistema operacional
.DS_Store
Thumbs.db
desktop.ini

# Editores
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
